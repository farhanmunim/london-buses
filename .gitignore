# Dependencies
node_modules/

# Secrets — NEVER commit any environment / API-key files
.env
.env.*
*.env
.env.local
.env.development
.env.production
*.pem
*.key
secrets.json
credentials.json

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Agent / assistant artefacts (not part of the shipped app)
.claude/
settings.json
screenshots/
reference/

# Intermediate build artefacts — not shipped at runtime.
# geocode_cache.json is force-added in the weekly workflow to persist
# postcodes.io results across runs.
data/source/

# Temp files
*.tmp
*.bak
*~

# Local test harness — one-off puppeteer / CSS scratchpads used during dev.
# Never ship; always regenerable.
_test_*.mjs
_tmp_*
package-lock.json.bak
